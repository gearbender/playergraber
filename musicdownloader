local url = "https://github.com/gearbender/playergraber/raw/refs/heads/main/Movie.dfpwm"

local response = http.get(url)
if not response then
    error("Download failed")
end

local file = fs.open("sound.dfpwm", "w")

while true do
    local chunk = response.read(512)
    if not chunk then break end
    file.write(chunk)
end

file.close()
response.close()

print("Download complete")
